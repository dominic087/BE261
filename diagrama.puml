@startuml sonic

class Accion{
 +Ejecutar[]
}

class Movimiento {
 +Mover[]
}

class Colision {
 +Detectar[]
}

class Danio{
 +Atacar[]
}

class Juego{
 +EstadoJuego : String
 +Iniciar[]
}

class Nivel{
 +EstadoNivel : String
 +Cargar[]
}

class Isla{
 +EstadoIsla : String
}

class Entidad{
 -PosicionX : float
 -PosicionY : float
 +EstadoActivo : boolean
 +Actualizar[]
}

class Personaje{
 -Velocidad : float
 +EstadoMovimiento : String
 +Mover[]
}

class Sonic{
 -Energia : int
 +EstadoAtaque : String
 +Atacar[]
}

class Enemigo{
 -Danio : int
 +EstadoHostil : boolean
 +Atacar[]
}

class Badnik{
 -Programa : String
 +EstadoRobot : String
}

class DoctorEggman{
 -Plan : String
 +EstadoControl : String
}

class Objeto{
 -EstadoInterno : String
 +EstadoExterno : String
 +AplicarEfecto()
}

class Anillo{
 -Valor : int
 +EstadoVisible : boolean
}

class Monitor{
 -Contenido : String
 +EstadoRoto : boolean
}

class Escudo{
 -Duracion : int
 +EstadoProteccion : boolean
}

class VidaExtra{
 -Cantidad : int
 +EstadoDisponible : boolean
}

class PuntoControl{
 -Registro : int
 +EstadoActivo : boolean
}

class Plataforma{
 -MovimientoInterno : String
 +EstadoSoporte : boolean
}

class Resorte{
 -Fuerza : int
 +EstadoSalto : boolean
}

class Pincho{
 -Danio : int
 +EstadoPeligro : boolean
}

class Bloque{
 -Resistencia : int
 +EstadoSolido : boolean
}

class Lava{
 -Temperatura : int
 +EstadoPeligro : boolean
}

class Teletransportador{
 -Destino : String
 +EstadoActivo : boolean
}

class MotorFisica{
 -Gravedad : float
 +EstadoMotor : boolean
 +Calcular()
}

class SistemaColision{
 -Algoritmo : String
 +EstadoDeteccion : boolean
 +Detectar()
}

class Maquina{
 -Energia : int
 +EstadoOperacion : boolean
}

'========================
' MEMORIA
'========================

class MemoriaJuego{
 -DatoInterno : String
 +DatoGuardado : String
 +Guardar()
 +Cargar()
}

Personaje --|> Entidad
Objeto --|> Entidad

Sonic --|> Personaje
Enemigo --|> Personaje

Badnik --|> Enemigo
DoctorEggman --|> Enemigo

Anillo --|> Objeto
Monitor --|> Objeto
Escudo --|> Objeto
VidaExtra --|> Objeto
PuntoControl --|> Objeto
Plataforma --|> Objeto
Resorte --|> Objeto
Pincho --|> Objeto
Bloque --|> Objeto
Lava --|> Objeto
Teletransportador --|> Objeto

Objeto ..|> Accion
Objeto ..|> Colision

Personaje ..|> Movimiento
Personaje ..|> Colision
Enemigo ..|> Danio

Juego *-- "1..*" Nivel
Juego *-- "1" MemoriaJuego

Nivel *-- "1" Isla
Nivel *-- "1" Sonic
Nivel *-- "1..*" Enemigo
Nivel *-- "0..*" Objeto

DoctorEggman *-- "1" Maquina

Personaje ..> MotorFisica
Personaje ..> SistemaColision
Enemigo ..> Sonic

@enduml